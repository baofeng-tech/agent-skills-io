{
  "name": "last30days-plugin",
  "description": "Requires python3, bash, and AISA_API_KEY. Uses the supplied AISA_API_KEY to send requests to https://api.aisa.one. Native-first ClawHub plugin for `last30days`. Ships the packaged AIsa skill with an `openclaw.plugin.json` manifest and a Claude-compatible bundle fallback. Research the last 30 days across Reddit, X, YouTube, TikTok, Instagram, Hacker News, Polymarket, GitHub, and grounded web search. Returns a ranked, clustered brief with citations. Use when the task needs recent social evidence, competitor comparisons, launch reactions, trend scans, or person/company profiles.",
  "version": "1.0.4",
  "author": {
    "name": "AIsa"
  },
  "homepage": "https://aisa.one",
  "repository": "https://github.com/baofeng-tech/agent-skills-io",
  "license": "MIT",
  "metadata": {
    "aisa": {
      "requires": {
        "bins": [
          "python3",
          "bash"
        ],
        "env": [
          "AISA_API_KEY"
        ]
      },
      "optionalEnv": [
        "LAST30DAYS_PLANNER_MODEL",
        "LAST30DAYS_RERANK_MODEL",
        "LAST30DAYS_FUN_MODEL",
        "AISA_MODEL",
        "AISA_BASE_URL",
        "XIAOHONGSHU_API_BASE",
        "LAST30DAYS_REASONING_PROVIDER",
        "INCLUDE_SOURCES",
        "LAST30DAYS_X_BACKEND",
        "LAST30DAYS_YOUTUBE_TRANSCRIPTS",
        "LAST30DAYS_REDDIT_COMMENTS",
        "GH_TOKEN",
        "GITHUB_TOKEN",
        "LAST30DAYS_CONFIG_DIR",
        "LAST30DAYS_DEBUG"
      ],
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one",
        "https://www.reddit.com",
        "https://hacker-news.firebaseio.com",
        "https://api.github.com",
        "https://www.xiaohongshu.com"
      ]
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "AISA_API_KEY": {
        "type": "string",
        "title": "Aisa Api Key",
        "description": "Provide AISA_API_KEY for the packaged AIsa skill runtime.",
        "format": "password"
      },
      "LAST30DAYS_PLANNER_MODEL": {
        "type": "string",
        "title": "Last30Days Planner Model",
        "description": "Optional runtime setting for LAST30DAYS_PLANNER_MODEL."
      },
      "LAST30DAYS_RERANK_MODEL": {
        "type": "string",
        "title": "Last30Days Rerank Model",
        "description": "Optional runtime setting for LAST30DAYS_RERANK_MODEL."
      },
      "LAST30DAYS_FUN_MODEL": {
        "type": "string",
        "title": "Last30Days Fun Model",
        "description": "Optional runtime setting for LAST30DAYS_FUN_MODEL."
      },
      "AISA_MODEL": {
        "type": "string",
        "title": "Aisa Model",
        "description": "Optional runtime setting for AISA_MODEL."
      },
      "AISA_BASE_URL": {
        "type": "string",
        "title": "Aisa Base Url",
        "description": "Optional runtime setting for AISA_BASE_URL."
      },
      "XIAOHONGSHU_API_BASE": {
        "type": "string",
        "title": "Xiaohongshu Api Base",
        "description": "Optional runtime setting for XIAOHONGSHU_API_BASE."
      },
      "LAST30DAYS_REASONING_PROVIDER": {
        "type": "string",
        "title": "Last30Days Reasoning Provider",
        "description": "Optional runtime setting for LAST30DAYS_REASONING_PROVIDER."
      },
      "INCLUDE_SOURCES": {
        "type": "string",
        "title": "Include Sources",
        "description": "Optional runtime setting for INCLUDE_SOURCES."
      },
      "LAST30DAYS_X_BACKEND": {
        "type": "string",
        "title": "Last30Days X Backend",
        "description": "Optional runtime setting for LAST30DAYS_X_BACKEND."
      },
      "LAST30DAYS_YOUTUBE_TRANSCRIPTS": {
        "type": "string",
        "title": "Last30Days Youtube Transcripts",
        "description": "Optional runtime setting for LAST30DAYS_YOUTUBE_TRANSCRIPTS."
      },
      "LAST30DAYS_REDDIT_COMMENTS": {
        "type": "string",
        "title": "Last30Days Reddit Comments",
        "description": "Optional runtime setting for LAST30DAYS_REDDIT_COMMENTS."
      },
      "GH_TOKEN": {
        "type": "string",
        "title": "Gh Token",
        "description": "Optional runtime setting for GH_TOKEN."
      },
      "GITHUB_TOKEN": {
        "type": "string",
        "title": "Github Token",
        "description": "Optional runtime setting for GITHUB_TOKEN."
      },
      "LAST30DAYS_CONFIG_DIR": {
        "type": "string",
        "title": "Last30Days Config Dir",
        "description": "Optional runtime setting for LAST30DAYS_CONFIG_DIR."
      },
      "LAST30DAYS_DEBUG": {
        "type": "string",
        "title": "Last30Days Debug",
        "description": "Optional runtime setting for LAST30DAYS_DEBUG."
      }
    },
    "required": [
      "AISA_API_KEY"
    ]
  },

{
  "name": "last30days-zh-plugin",
  "version": "1.0.0",
  "description": "Requires python3, bash, and AISA_API_KEY. Native-first ClawHub plugin for `last30days-zh`. Ships the packaged AIsa skill with an `openclaw.plugin.json` manifest and a Claude-compatible bundle fallback. 通过 AIsa 执行网页、多源或近 30 天研究检索。触发条件：当用户需要搜索、研究、比对或趋势归纳时使用。支持多源检索与结构化输出。",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "aisa",
    "clawhub",
    "openclaw",
    "native-plugin",
    "agent-skill"
  ],
  "homepage": "https://aisa.one",
  "repository": {
    "type": "git",
    "url": "https://github.com/AIsa-team/agent-skills.git"
  },
  "metadata": {
    "aisa": {
      "requires": {
        "bins": [
          "python3",
          "bash"
        ],
        "env": [
          "AISA_API_KEY"
        ]
      },
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    }
  },
  "aisa": {
    "requires": {
      "bins": [
        "python3",
        "bash"
      ],
      "env": [
        "AISA_API_KEY"
      ]
    },
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one"
    ]
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": "^1.0.0"
    },
    "build": {
      "openclawVersion": "^1.0.0"
    },
    "runtimeRequirements": {
      "bins": [
        "python3",
        "bash"
      ],
      "env": [
        "AISA_API_KEY"
      ],
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    }
  }
}

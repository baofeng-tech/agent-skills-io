{
  "name": "last30days-zh-plugin",
  "version": "1.0.0",
  "description": "Requires python3, bash, and AISA_API_KEY. Uses the supplied AISA_API_KEY to send requests to https://api.aisa.one. Native-first ClawHub plugin for `last30days-zh`. Ships the packaged AIsa skill with an `openclaw.plugin.json` manifest and a Claude-compatible bundle fallback. 聚合最近 30 天的 Reddit、X/Twitter、YouTube、TikTok、Instagram、Hacker News、Polymarket 和 web search 结果. Use when: the user needs recent multi-source research across the last 30 days.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "aisa",
    "clawhub",
    "openclaw",
    "native-plugin",
    "agent-skill",
    "twitter",
    "youtube",
    "search",
    "research",
    "market"
  ],
  "homepage": "https://aisa.one",
  "repository": {
    "type": "git",
    "url": "https://github.com/baofeng-tech/agent-skills-io.git"
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "AISA_API_KEY": {
        "type": "string",
        "title": "Aisa Api Key",
        "description": "Provide AISA_API_KEY for the packaged AIsa skill runtime.",
        "format": "password"
      },
      "LAST30DAYS_RERANK_MODEL": {
        "type": "string",
        "title": "Last30Days Rerank Model",
        "description": "Optional runtime setting for LAST30DAYS_RERANK_MODEL."
      },
      "AISA_MODEL": {
        "type": "string",
        "title": "Aisa Model",
        "description": "Optional runtime setting for AISA_MODEL."
      },
      "LAST30DAYS_PLANNER_MODEL": {
        "type": "string",
        "title": "Last30Days Planner Model",
        "description": "Optional runtime setting for LAST30DAYS_PLANNER_MODEL."
      },
      "AISA_BASE_URL": {
        "type": "string",
        "title": "Aisa Base Url",
        "description": "Optional runtime setting for AISA_BASE_URL."
      },
      "XIAOHONGSHU_API_BASE": {
        "type": "string",
        "title": "Xiaohongshu Api Base",
        "description": "Optional runtime setting for XIAOHONGSHU_API_BASE."
      }
    },
    "required": [
      "AISA_API_KEY"
    ]
  },
  "runtimeRequirements": {
    "bins": [
      "python3",
      "bash"
    ],
    "env": [
      "AISA_API_KEY"
    ],
    "optionalEnv": [
      "LAST30DAYS_RERANK_MODEL",
      "AISA_MODEL",
      "LAST30DAYS_PLANNER_MODEL",
      "AISA_BASE_URL",
      "XIAOHONGSHU_API_BASE"
    ],
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one",
      "https://www.reddit.com",
      "https://hacker-news.firebaseio.com",
      "https://www.xiaohongshu.com",
      "http://host.docker.internal:18060"
    ]
  },

{
  "name": "aisa-youtube-search-plugin",
  "version": "1.0.1",
  "description": "Requires AISA_API_KEY. Uses the supplied AISA_API_KEY to send requests to https://api.aisa.one. Native-first ClawHub plugin for `aisa-youtube-search`. Ships the packaged AIsa skill with an `openclaw.plugin.json` manifest and a Claude-compatible bundle fallback. Search YouTube videos, channels, and playlists through the AIsa YouTube relay with one API key. Use when the user asks for YouTube discovery, query expansion, or pagination without managing Google credentials.",
  "license": "MIT-0",
  "type": "module",
  "keywords": [
    "aisa",
    "clawhub",
    "openclaw",
    "native-plugin",
    "agent-skill",
    "youtube",
    "search",
    "video"
  ],
  "homepage": "https://aisa.one",
  "repository": {
    "type": "git",
    "url": "https://github.com/baofeng-tech/agent-skills-io.git"
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "AISA_API_KEY": {
        "type": "string",
        "title": "Aisa Api Key",
        "description": "Provide AISA_API_KEY for the packaged AIsa skill runtime.",
        "format": "password"
      }
    },
    "required": [
      "AISA_API_KEY"
    ]
  },
  "runtimeRequirements": {
    "env": [
      "AISA_API_KEY"
    ],
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one"
    ]
  },
  "metadata": {
    "aisa": {
      "requires": {
        "env": [
          "AISA_API_KEY"
        ]
      },
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    }
  },
  "requires": {
    "env": [
      "AISA_API_KEY"
    ]
  },
  "primaryEnv": "AISA_API_KEY",
  "networkTargets": [
    "https://api.aisa.one"
  ],
  "aisa": {
    "requires": {
      "env": [
        "AISA_API_KEY"
      ]
    },
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one"
    ]
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": "^1.0.0"
    },
    "build": {
      "openclawVersion": "^1.0.0"
    },
    "runtimeRequirements": {
      "env": [
        "AISA_API_KEY"
      ],
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    },
    "configUiHints": {
      "AISA_API_KEY": {
        "label": "Aisa Api Key",
        "help": "Required runtime secret for AISA_API_KEY.",
        "sensitive": true
      },
      "emoji": "▶️"
    },
    "environment": {
      "externalServices": [
        {
          "name": "api.aisa.one"
        }
      ]
    }
  }
}

{
  "name": "stock-portfolio-plugin",
  "description": "Requires python3, and AISA_API_KEY. Uses the supplied AISA_API_KEY to send requests to https://api.aisa.one. Native-first ClawHub plugin for `stock-portfolio`. Ships the packaged AIsa skill with an `openclaw.plugin.json` manifest and a Claude-compatible bundle fallback. Manage investment portfolios with live P&L tracking via AIsa API. Create, add, update, remove positions, rename, and show portfolio summary with real-time profit/loss. Use when the user wants to track investments, manage a portfolio, check P&L, or add/remove holdings.",
  "version": "1.0.0",
  "author": {
    "name": "AIsa"
  },
  "homepage": "https://aisa.one",
  "repository": "https://github.com/baofeng-tech/agent-skills-io",
  "license": "Apache-2.0",
  "metadata": {
    "aisa": {
      "requires": {
        "bins": [
          "python3"
        ],
        "env": [
          "AISA_API_KEY"
        ]
      },
      "optionalEnv": [
        "AISA_BASE_URL",
        "AISA_MODEL"
      ],
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "AISA_API_KEY": {
        "type": "string",
        "title": "Aisa Api Key",
        "description": "Provide AISA_API_KEY for the packaged AIsa skill runtime.",
        "format": "password"
      },
      "AISA_BASE_URL": {
        "type": "string",
        "title": "Aisa Base Url",
        "description": "Optional runtime setting for AISA_BASE_URL."
      },
      "AISA_MODEL": {
        "type": "string",
        "title": "Aisa Model",
        "description": "Optional runtime setting for AISA_MODEL."
      }
    },
    "required": [
      "AISA_API_KEY"
    ]
  },
  "runtimeRequirements": {
    "bins": [
      "python3"
    ],
    "env": [
      "AISA_API_KEY"
    ],
    "optionalEnv": [
      "AISA_BASE_URL",
      "AISA_MODEL"
    ],
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one"
    ]
  },
  "aisa": {
    "requires": {
      "bins": [
        "python3"
      ],
      "env": [
        "AISA_API_KEY"
      ]
    },
    "optionalEnv": [
      "AISA_BASE_URL",
      "AISA_MODEL"
    ],
    "primaryEnv": "AISA_API_KEY",
    "networkTargets": [
      "https://api.aisa.one"
    ]
  },
  "openclaw": {
    "runtimeRequirements": {
      "bins": [
        "python3"
      ],
      "env": [
        "AISA_API_KEY"
      ],
      "optionalEnv": [
        "AISA_BASE_URL",
        "AISA_MODEL"
      ],
      "primaryEnv": "AISA_API_KEY",
      "networkTargets": [
        "https://api.aisa.one"
      ]
    }
  }
}
